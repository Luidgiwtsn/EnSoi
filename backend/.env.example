# Copier ce fichier en .env et remplir les valeurs
# Ne jamais commiter .env

# 
# Base de données
# 
# Local : URL postgres locale
# Railway prod : injectée automatiquement via ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://user:password@localhost:5432/ensoi

# 
# JWT
# 
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
# IMPORTANT : utiliser une clé DIFFÉRENTE en prod et en dev
SECRET_KEY=REMPLACER
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# 
# Groq (LLM)
# 
# Obtenir sur https://console.groq.com
GROQ_API_KEY=REMPLACER
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT=8

# 
# CORS - origines autorisées séparées par des virgules
# 
# Utilisées uniquement pour la whitelist CORS.
# Local : FRONTEND_URLS=http://localhost:5173,http://127.0.0.1:5173
# Prod  : FRONTEND_URLS=https://ensoi.vercel.app
FRONTEND_URLS=http://localhost:5173,http://127.0.0.1:5173

# URL publique canonique du frontend (une seule) - utilisée pour construire
# les liens de partage publics (ex: /public/{token}).
# Séparée de FRONTEND_URLS car ce dernier peut contenir plusieurs origines (CORS).
# Local : FRONTEND_PUBLIC_URL=http://localhost:5173
# Prod  : FRONTEND_PUBLIC_URL=https://ensoi.vercel.app
FRONTEND_PUBLIC_URL=http://localhost:5173

# 
# Environnement
# 
# Local : development
# Railway prod : production
ENVIRONMENT=development
